{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "types": [
      "node"
    ],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./"
  },
  "include": [
    "src/**/*",
    "globals.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}