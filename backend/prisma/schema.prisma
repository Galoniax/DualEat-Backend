// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "windows", "debian-openssl-3.0.x"]
}

// Enums
enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  INACTIVE
  TRIAL
  ACTIVE
  CANCELLED
}

enum ContentType {
  POST
  COMMENT
}

enum VoteType {
  UP
  DOWN
}

enum OrderStatus {
  IN_PROGRESS // Orden en proceso de pago/checkout (se elimina si expira)
  PENDING // Nuevo pedido, esperando pago o confirmación (manual/staff)
  PAID // Pedido pagado, esperando preparación
  COMPLETED // Pedido completado y entregado
  CANCELLED // Pedido cancelado por el usuario o el local
  READY // Pedido listo para pagar
}

enum LocalUserRole {
  admin
  staff
}

enum TypesCategory {
  Tipos_de_comida
  Estilos_o_dietas
  Origen_y_cultura
}

enum NotificationFrequency {
  ALWAYS
  NONE
}

enum NotificationContentType {
  POST
  COMMUNITY
  LOCAL
  ORDER
  COMMENT
}

enum Unit {
  GRAMOS
  KILOGRAMOS
  MILILITROS
  LITROS
  CUCHARADITA
  CUCHARADA
  TAZA
  UNIDAD
  PIZCA
  PAQUETE
  OPCIONAL
}

enum DayOfWeek {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

enum LocalEventType {
  TASK
  PAYMENT
  MEETING
  MAINTENANCE
  OTHER
}

enum EventStatus {
  PENDING
  COMPLETED
  CANCELLED
  IN_PROGRESS
}

enum SubscriptionStateMP {
  inactive
  authorized
  active
  paused
  cancelled
  finished
}

enum SubscriptionType {
  LOCAL
  COMMUNITY_USER
}

enum SubscriptionPlan {
  LOCAL_MONTHLY
  LOCAL_ANNUAL
  COMMUNITY_USER_MONTHLY
  COMMUNITY_USER_ANNUAL
}

enum TicketType {
  PAYMENT
  WEB
  QUERY
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportSenderRole {
  LOCAL
  ADMIN
}

// ========================================================
// MODELO DE USUARIOS Y NOTIFICACIONES
// ========================================================
model User {
  // 1. IDENTIFICACIÓN Y PERFIL
  id         String  @id @default(nanoid(14)) @map("id")
  slug       String  @unique
  name       String
  email      String  @unique
  avatar_url String?
  role       Role    @default(USER)
  active     Boolean @default(true)
  verified   Boolean @default(false)

  // 2. AUTENTICACIÓN Y SEGURIDAD
  password_hash    String?
  provider         String    @default("local")
  reset_code       String?
  reset_expires_at DateTime?

  // 3. CONFIGURACIÓN Y NEGOCIO
  is_business         Boolean               @default(false)
  subscription_status SubscriptionStatus    @default(INACTIVE)
  trial_ends_at       DateTime?
  notificationsPref   NotificationFrequency @default(ALWAYS)

  // 4. TIMESTAMPS
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // 5. RELACIONES
  //coupons             Coupon[]
  notifications       Notification[]
  local_users         LocalUser[]
  local_reviews       LocalReview[]
  votes               Vote[]            @relation("UserVotes")
  created_communities Community[]       @relation("Creator")
  community_members   CommunityMember[]
  posts               Post[]
  comments            PostComment[]
  orders              Order[]
  subscriptions       Subscription[]
  preferences         UserPreference[]
  recipes             Recipe[]
  support_messages    SupportMessage[]

  received_replies PostComment[] @relation("RepliedUser")

  @@index([email])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, name: "user_name_trgm_idx")
}

model UserPreference {
  id      Int    @id @default(autoincrement())
  user    User   @relation(fields: [user_id], references: [id])
  user_id String

  food_category_id String?
  community_tag_id String?

  foodCategory FoodCategory? @relation(fields: [food_category_id], references: [id], onDelete: Cascade)
  communityTag CommunityTag? @relation(fields: [community_tag_id], references: [id], onDelete: Cascade)

  @@unique([user_id, food_category_id])
  @@unique([user_id, community_tag_id])
}

model Notification {
  id           String                  @id @default(cuid()) @map("id")
  user_id      String
  content_type NotificationContentType
  content_id   String? // ID de la entidad a la que se refiere la notificación

  title   String
  message String

  metadata   Json?
  read       Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at(sort: Desc)])
}

// ========================================================
// MODELO DE NEGOCIOS Y LOCALES
// ========================================================
model Local {
  id          String  @id @default(nanoid(10)) @map("id")
  slug        String  @unique
  name        String
  description String?
  address     String
  phone       String?
  email       String?

  type_local String
  image_url  String

  latitude  Float
  longitude Float

  average_rating Float    @default(0)
  active         Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  local_users LocalUser[]
  foods       Food[]
  orders      Order[]
  reviews     LocalReview[]

  promotions      Promotion[]
  //coupons         Coupon[]
  schedules       LocalSchedule[]
  calendar_events LocalCalendarEvent[]
  notes           LocalNote[]
  Subscription    Subscription[]
  support_tickets SupportTicket[]

  categories  FoodCategory[] @relation("LocalCategories")
  credentials Credentials?

  @@index([name, latitude, longitude])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, name: "local_name_trgm_idx")
}

model LocalSchedule {
  id          String    @id @default(cuid())
  day_of_week DayOfWeek
  open_time   String
  close_time  String
  local_id    String
  local       Local     @relation(fields: [local_id], references: [id])

  @@unique([local_id, day_of_week, open_time, close_time])
}

model LocalCalendarEvent {
  id       String @id @default(cuid()) @map("id")
  local_id String
  local    Local  @relation(fields: [local_id], references: [id])

  title       String
  description String?
  start_time  DateTime
  end_time    DateTime?
  is_full_day Boolean   @default(false)

  event_type LocalEventType @default(TASK)
  status     EventStatus    @default(PENDING)
  priority   Int            @default(1)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([local_id, start_time])
}

model LocalNote {
  id       String @id @default(cuid()) @map("id")
  local_id String
  local    Local  @relation(fields: [local_id], references: [id])

  title        String
  content      String
  is_pinned    Boolean   @default(false)
  is_completed Boolean   @default(false)
  due_date     DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([local_id, is_pinned, due_date])
}

model LocalUser {
  id       String        @id @default(cuid()) @map("id")
  user     User          @relation(fields: [user_id], references: [id])
  user_id  String
  local    Local         @relation(fields: [local_id], references: [id])
  local_id String
  role     LocalUserRole @default(staff)

  joined_at  DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([user_id, local_id])
  @@index([local_id])
}

model LocalReview {
  id         String   @id @default(cuid()) @map("id")
  user       User     @relation(fields: [user_id], references: [id])
  user_id    String
  local      Local    @relation(fields: [local_id], references: [id])
  local_id   String
  rating     Int
  comment    String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  order    Order  @relation(fields: [order_id], references: [id])
  order_id String @unique

  @@index([user_id])
  // @@unique([user_id, local_id]) Una por pedido, no por usuario-local para permitir múltiples reseñas si hay múltiples pedidos
}

// ========================================================
// MODELO DE COMIDAS Y CATEGORÍAS
// ========================================================
model FoodCategory {
  id       String        @id @default(nanoid(8)) @map("id")
  name     String        @unique
  tipo     TypesCategory
  icon_url String?

  foods            Food[]
  user_preferences UserPreference[]

  locals Local[] @relation("LocalCategories")

  @@index([name])
}

model Food {
  id          String @id @default(nanoid(10)) @map("id")
  local_id    String
  category_id String

  name        String
  description String?
  price       Float
  image_url   String?
  available   Boolean @default(true)

  votes_up   Int @default(0)
  votes_down Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  local    Local        @relation(fields: [local_id], references: [id], onDelete: Cascade)
  category FoodCategory @relation(fields: [category_id], references: [id])

  order_items OrderItem[]
  promotions  Promotion?

  @@index([local_id])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, name: "food_name_trgm_idx")
  @@index([category_id])
}

model Promotion {
  id String @id @default(nanoid(10))

  local_id String
  food_id  String? @unique

  title       String?
  description String?

  discount_pct Float

  starts_at DateTime?
  ends_at   DateTime?

  active Boolean @default(true)

  local Local @relation(fields: [local_id], references: [id], onDelete: Cascade)
  food  Food? @relation(fields: [food_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())

  @@index([discount_pct])
}

/**
 * model Coupon {
 * id   String @id @default(cuid())
 * code String @unique
 * local_id String?
 * user_id  String?
 * discount_pct   Float?
 * discount_value Float?
 * max_uses   Int?
 * used_count Int  @default(0)
 * expires_at DateTime?
 * active Boolean @default(true)
 * local Local? @relation(fields: [local_id], references: [id])
 * user  User?  @relation(fields: [user_id], references: [id])
 * created_at DateTime @default(now())
 * }
 */

// ========================================================
// MODELO DE VOTOS
// ========================================================
model Vote {
  user         User        @relation("UserVotes", fields: [user_id], references: [id], onDelete: Cascade)
  user_id      String
  content_type ContentType
  content_id   String
  vote_type    VoteType
  created_at   DateTime    @default(now())
  updated_at   DateTime    @updatedAt

  @@id([user_id, content_id, content_type])
  @@index([user_id, content_type, content_id])
}

// ========================================================
// MODELO DE COMUNIDADES
// ========================================================
model Community {
  id          String  @id @default(nanoid(10)) @map("id")
  slug        String  @unique
  name        String  @unique
  description String
  image_url   String?
  banner_url  String?

  total_members Int      @default(1)
  creator       User     @relation("Creator", fields: [creator_id], references: [id])
  creator_id    String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  active        Boolean  @default(true)

  members CommunityMember[]
  posts   Post[]

  tags CommunityTag[] @relation("CommunityTags")

  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, name: "community_name_trgm_idx")
}

model TagCategory {
  id          Int     @id @default(autoincrement())
  slug        String  @unique
  name        String  @unique
  description String?
  icon_url    String?

  communityTags CommunityTag[]
}

model CommunityTag {
  id     String  @id @default(nanoid(8)) @map("id")
  name   String  @unique
  active Boolean @default(true)

  category_id Int?
  category    TagCategory? @relation(fields: [category_id], references: [id])

  communities      Community[]      @relation("CommunityTags")
  user_preferences UserPreference[]
}

model CommunityMember {
  id                     String                @id @default(cuid()) @map("id")
  user                   User                  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id                String
  community              Community             @relation(fields: [community_id], references: [id], onDelete: Cascade)
  community_id           String
  receives_notifications NotificationFrequency @default(ALWAYS)
  joined_at              DateTime              @default(now())
  updated_at             DateTime              @updatedAt
  is_moderator           Boolean               @default(false)

  @@unique([user_id, community_id])
  @@index([community_id])
}

// ========================================================
// MODELO DE RECETAS
// ========================================================
model Recipe {
  id          String @id @default(nanoid(10)) @map("id")
  slug        String @unique
  user        User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id     String
  name        String
  description String
  total_time  Int?
  main_image  String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  ingredients RecipeIngredient[]
  steps       RecipeStep[]
  posts       Post[]

  @@index([user_id])
  @@index([created_at(sort: Desc)])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, name: "recipe_name_trgm_idx")
}

model RecipeIngredient {
  id            String     @id @default(cuid()) @map("id")
  recipe        Recipe     @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  recipe_id     String
  ingredient    Ingredient @relation(fields: [ingredient_id], references: [id])
  ingredient_id Int
  quantity      String
  unit          Unit
  notes         String?

  @@index([ingredient_id])
  @@index([recipe_id])
}

model RecipeStep {
  id             String @id @default(cuid()) @map("id")
  recipe         Recipe @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  recipe_id      String
  step_number    Int
  description    String
  estimated_time Int    @default(0)

  @@unique([recipe_id, step_number])
}

// ========================================================
// MODELO DE POSTS
// ========================================================
model Post {
  id           String    @id @default(nanoid(10)) @map("id")
  slug         String    @unique
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id      String
  community    Community @relation(fields: [community_id], references: [id], onDelete: Cascade)
  community_id String
  title        String
  content      String
  image_urls   String[]

  votes_up       Int      @default(0)
  votes_down     Int      @default(0)
  total_comments Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  edited         Boolean  @default(false)
  active         Boolean  @default(true)

  comments  PostComment[]
  recipe    Recipe?       @relation(fields: [recipe_id], references: [id], onDelete: SetNull)
  recipe_id String?

  @@index([created_at(sort: Desc)])
  @@index([community_id])
  @@index([user_id, active])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin, name: "post_title_trgm_idx")
}

model PostComment {
  id      String @id @default(cuid()) @map("id")
  user    User   @relation(fields: [user_id], references: [id])
  user_id String
  post    Post   @relation(fields: [post_id], references: [id], onDelete: Cascade)
  post_id String

  parent_comment    PostComment? @relation("CommentReplies", fields: [parent_comment_id], references: [id], onDelete: Cascade)
  parent_comment_id String?

  reply_to_user_id String?
  reply_to_user    User?   @relation("RepliedUser", fields: [reply_to_user_id], references: [id], onDelete: SetNull)

  content    String
  votes_up   Int      @default(0)
  votes_down Int      @default(0)
  edited     Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  active     Boolean  @default(true)

  replies PostComment[] @relation("CommentReplies")

  @@index([post_id])
  @@index([user_id])
  @@index([parent_comment_id])
  @@index([content(ops: raw("gin_trgm_ops"))], type: Gin, name: "post_content_trgm_idx")
}

// ========================================================
// MODELO DE INGREDIENTES
// ========================================================

model Ingredient {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  calories    Int     @default(0)
  proteins    Float   @default(0.0)
  carbs       Float   @default(0.0)
  fat         Float   @default(0.0)

  recipe_ingredients RecipeIngredient[]
}

// ========================================================
// MODELO DE PEDIDOS Y SUS DETALLES
// ========================================================
model Order {
  id             String      @id @default(nanoid(10)) @map("id")
  user           User?       @relation(fields: [user_id], references: [id], onDelete: SetNull)
  user_id        String?
  local          Local       @relation(fields: [local_id], references: [id], onDelete: Cascade)
  local_id       String
  total          Float
  status         OrderStatus @default(PENDING)
  payment_method String?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  short_code    String?
  delivery_date DateTime?
  notes         String?

  order_items OrderItem[]
  review      LocalReview?

  @@unique([local_id, short_code])
}

model OrderItem {
  id         String @id @default(cuid()) @map("id")
  order      Order  @relation(fields: [order_id], references: [id], onDelete: Cascade)
  order_id   String
  food       Food   @relation(fields: [food_id], references: [id])
  food_id    String
  quantity   Int    @default(1)
  unit_price Float
  subtotal   Float
}

// ========================================================
// MODELO DE SUSCRIPCIONES
// ========================================================
model Subscription {
  id String @id @default(cuid()) @map("id")

  user    User   @relation(fields: [user_id], references: [id])
  user_id String

  local    Local?  @relation(fields: [local_id], references: [id])
  local_id String? @map("local_id")

  mp_preapproval_id String

  subscription_type SubscriptionType
  plan              SubscriptionPlan
  amount            Float
  currency_id       String              @default("ARS")
  status            SubscriptionStateMP @default(authorized)

  start_date        DateTime
  next_payment_date DateTime?
  end_date          DateTime?
  auto_renew        Boolean   @default(true)

  payment_history Json?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([user_id, local_id, subscription_type])
  @@index([mp_preapproval_id])
}

// ========================================================
// MODELO DE SOPORTE Y CHAT
// ========================================================

model SupportTicket {
  id       String       @id @default(nanoid(10)) @map("id")
  local_id String
  type     TicketType
  status   TicketStatus @default(OPEN)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  local    Local            @relation(fields: [local_id], references: [id])
  messages SupportMessage[]

  @@index([local_id])
  @@index([status])
}

model SupportMessage {
  id          String            @id @default(cuid()) @map("id")
  ticket_id   String
  sender_id   String
  sender_role SupportSenderRole
  content     String
  read        Boolean           @default(false)

  created_at DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [sender_id], references: [id])

  @@index([ticket_id])
  @@index([sender_id])
}

model Credentials {
  id            String   @id @default(cuid())
  local_id      String   @unique
  access_token  String // Token con el que harás los cobros de sus platos
  refresh_token String // Token para renovar el access_token cuando expire
  public_key    String // Llave pública del local
  user_id_mp    String // ID de usuario de Mercado Pago de ese local
  expires_in    Int // Tiempo de expiración del token
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  local Local @relation(fields: [local_id], references: [id], onDelete: Cascade)
}
